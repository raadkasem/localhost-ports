{
  "manifest_version": 3,
  "name": "Localhost Ports Dashboard",
  "version": "1.1.0",
  "description": "Instantly see all your running localhost services and open them with one click.",
  "author": "Raad Kasem",
  "homepage_url": "https://raadkasem.dev",
  "permissions": [
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "http://localhost/*",
    "http://127.0.0.1/*",
    "http://0.0.0.0/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Localhost Ports Dashboard"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
